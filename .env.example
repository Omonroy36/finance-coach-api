# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1
APP_NAME=FinanceCoach

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://finance_user:finance_pass@localhost:5432/finance_db?schema=public

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=finance:

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && cat private.pem | base64
JWT_PRIVATE_KEY_BASE64=<base64-encoded-rsa-private-key>
JWT_PUBLIC_KEY_BASE64=<base64-encoded-rsa-public-key>
JWT_ACCESS_TOKEN_TTL=900        # 15 minutes in seconds
JWT_REFRESH_TOKEN_TTL=2592000   # 30 days in seconds
JWT_ISSUER=finance-coach
JWT_AUDIENCE=finance-coach-app

# ─── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=<64-hex-chars>

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_BASE64=

# ─── Plaid ─────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox           # sandbox | development | production
PLAID_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/plaid

# ─── Notifications ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY_BASE64=
RESEND_API_KEY=             # Email provider
FROM_EMAIL=noreply@yourapp.com

# ─── Cors ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001,https://yourapp.com

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=5
RATE_LIMIT_GLOBAL=300

# ─── Storage ───────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
